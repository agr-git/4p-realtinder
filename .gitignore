cookies.json
storage-state.json
auth-state.json
.auth/
profiles/
user-data-dir/

# --- Scraped data ----------------------------------------------------------
# Listings carry agent names, phones and emails — personal data under
# Ley 1581 de 2012. Keep it out of a public repo.
data/
output/
scraped/
exports/
*.csv
*.jsonl
*.sqlite
*.sqlite3
*.db
!data/schema/**
!**/fixtures/**

