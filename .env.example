# .env.example — qué variables hace falta definir, sin valores.
#
# Este archivo se commitea; `.env` NO. Los secretos de producción no viven
# en el repo: van al vault de credenciales de n8n (lado VPS) y a las env
# vars de Vercel (lado frontend). Ver directives/deploy.md.

# --- Frontend (env vars de Vercel) ---------------------------------------
# La anon key es pública por diseño y va al bundle del navegador. En Fase 1
# eso es aceptable porque los datos son listings públicos de solo lectura.
# Cuando entre Auth en Fase 4, las políticas RLS son las que pasan a mandar.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Ingestión (vault de credenciales de n8n, NO un .env en el VPS) -------
# La service_role key salta RLS por completo. Solo la usa n8n para escribir,
# y nunca sale del vault: jamás al frontend, jamás a un export de workflow.
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Alertas operativas ---------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Fase 2, todavía no en uso -------------------------------------------
FIRECRAWL_API_KEY=
